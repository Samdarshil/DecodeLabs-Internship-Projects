# ── Copy this file to .env and edit values ───────────────────────────────────
# cp .env.example .env

# Server
DEBUG=false
LOG_LEVEL=INFO

# CORS — set this to your frontend's deployed URL in production
FRONTEND_URL=http://localhost:5173

# Model
MODEL_DIR=models_store
MODEL_FILE=breast_cancer_v1.joblib
META_FILE=metadata.json

# Rate limiting — uncomment to enable Redis-backed limiting
# REDIS_URL=redis://localhost:6379/0
